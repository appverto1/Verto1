{
  "entities": {
    "ActivityLog": {
      "title": "Activity Log",
      "description": "Logs of user actions for audit and tracking",
      "type": "object",
      "properties": {
        "user_id": { "type": "string", "description": "The UID of the professional who performed the action" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the action occurred" },
        "professional": { "type": "string", "description": "Name of the professional" },
        "action": { "type": "string", "description": "The action performed (e.g., 'Login')" },
        "details": { "type": "string", "description": "Detailed description of the action" },
        "category": { "type": "string", "enum": ["clinical", "management", "system"], "description": "Category of the action" }
      },
      "required": ["user_id", "timestamp", "action"]
    },
    "Patient": {
      "title": "Patient",
      "description": "Patient information and clinical metadata",
      "type": "object",
      "properties": {
        "therapist_id": { "type": "string", "description": "UID of the therapist managing this patient" },
        "clinic_id": { "type": "string", "description": "ID of the clinic this patient belongs to" },
        "name": { "type": "string", "description": "Patient's full name" },
        "email": { "type": "string", "format": "email", "description": "Patient's email address (unique identifier for history)" },
        "phone": { "type": "string", "description": "Patient's phone number" },
        "age": { "type": "integer", "description": "Patient's age" },
        "diagnosis": { "type": "string", "description": "Clinical diagnosis or reason for consultation" },
        "status": { "type": "string", "enum": ["active", "inactive", "delinquent"], "description": "Patient status" }
      },
      "required": ["therapist_id", "name", "email"]
    },
    "Note": {
      "title": "Clinical Note",
      "description": "Clinical evolution notes for a patient",
      "type": "object",
      "properties": {
        "therapist_id": { "type": "string", "description": "UID of the therapist who wrote the note" },
        "patient_id": { "type": "string", "description": "ID of the patient in the patients collection" },
        "patient_email": { "type": "string", "format": "email", "description": "Email of the patient for cross-account history" },
        "text": { "type": "string", "description": "The content of the note" },
        "visibility": { 
          "type": "string", 
          "enum": ["private", "patient", "professional"],
          "description": "Visibility level: private (author only), patient (author, patient, and other therapists), professional (author and other therapists)" 
        },
        "subject": { "type": "string", "description": "Subject of the note" },
        "original_id": { "type": "string", "description": "The ID of the original private note if this is a shared copy." },
        "created_at": { "type": "string", "format": "date-time", "description": "Creation timestamp" }
      },
      "required": ["therapist_id", "patient_email", "text", "visibility"]
    },
    "HistoryItem": {
      "title": "History Item",
      "description": "A record of a task, trial, or event in the patient's history",
      "type": "object",
      "properties": {
        "therapist_id": { "type": "string", "description": "UID of the therapist (if recorded by professional)" },
        "patient_id": { "type": "string", "description": "ID of the patient" },
        "patient_email": { "type": "string", "format": "email", "description": "Email of the patient" },
        "type": { "type": "string", "description": "Type of event (e.g., 'task', 'photo', 'checkin')" },
        "title": { "type": "string", "description": "Title of the activity" },
        "score": { "type": "number", "description": "Score achieved (if applicable)" },
        "energy": { "type": "number", "description": "Energy level or percentage" },
        "note": { "type": "string", "description": "Observations or notes" },
        "icon": { "type": "string", "description": "Icon representing the activity" },
        "image": { "type": "string", "description": "URL to an associated image" },
        "created_at": { "type": "string", "format": "date-time", "description": "Timestamp of the event" }
      },
      "required": ["patient_email", "type", "title"]
    },
    "User": {
      "title": "User Profile",
      "description": "Extended user profile data",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Full name" },
        "role": { 
          "type": "string", 
          "enum": ["coordinator", "therapist", "receptionist", "patient", "admin"], 
          "description": "User role within the clinic" 
        },
        "email": { "type": "string", "format": "email", "description": "Email address" },
        "crp": { "type": "string", "description": "Professional registration number" },
        "plan": { "type": "string", "description": "Subscription plan" },
        "age": { "type": "integer", "description": "Age (for patients)" },
        "clinic_id": { "type": "string", "description": "ID of the clinic this user belongs to" }
      },
      "required": ["name", "role", "email"]
    },
    "Payment": {
      "title": "Payment",
      "description": "Simple payment record for a patient",
      "type": "object",
      "properties": {
        "patient_id": { "type": "string", "description": "ID of the patient" },
        "clinic_id": { "type": "string", "description": "ID of the clinic" },
        "amount": { "type": "number", "description": "Amount paid" },
        "date": { "type": "string", "format": "date-time", "description": "Payment date" },
        "method": { "type": "string", "enum": ["pix", "card", "cash", "transfer"], "description": "Payment method" },
        "status": { "type": "string", "enum": ["paid", "pending", "overdue"], "description": "Payment status" }
      },
      "required": ["patient_id", "clinic_id", "amount", "date", "status"]
    },
    "Invitation": {
      "title": "Clinic Invitation",
      "description": "An invitation for a professional to join a clinic",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email", "description": "Email of the invited professional" },
        "clinic_id": { "type": "string", "description": "ID of the clinic inviting the professional" },
        "clinic_name": { "type": "string", "description": "Name of the clinic for the invitation email/UI" },
        "role": { "type": "string", "enum": ["therapist", "receptionist"], "description": "Role assigned to the invited professional" },
        "status": { "type": "string", "enum": ["pending", "accepted", "declined"], "description": "Status of the invitation" },
        "invited_by": { "type": "string", "description": "UID of the user who sent the invitation" },
        "created_at": { "type": "string", "format": "date-time", "description": "When the invitation was sent" }
      },
      "required": ["email", "clinic_id", "role", "status", "invited_by", "created_at"]
    }
  },
  "firestore": {
    "/activity_logs/{logId}": {
      "schema": "ActivityLog",
      "description": "System activity logs"
    },
    "/patients/{patientId}": {
      "schema": "Patient",
      "description": "Patient records"
    },
    "/notes/{noteId}": {
      "schema": "Note",
      "description": "Clinical notes"
    },
    "/history/{historyId}": {
      "schema": "HistoryItem",
      "description": "Patient history timeline"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/payments/{paymentId}": {
      "schema": "Payment",
      "description": "Payment records"
    },
    "/invitations/{invitationId}": {
      "schema": "Invitation",
      "description": "Clinic invitations"
    }
  }
}
